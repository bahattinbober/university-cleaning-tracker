# NOT: # ve $ gibi özel karakter içeren değerleri MUTLAKA çift tırnak içine alın
# dotenv tırnaksız değerlerde # karakterini yorum başlangıcı sayar

PORT=4000

# En az 64 karakter, rastgele üretilmiş string kullanın:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace_with_a_long_random_secret"

# Sunucu ilk açıldığında seed edilecek admin hesabı.
# DB'de bu email zaten varsa seed atlanır.
# İkisi de boş bırakılırsa otomatik admin OLUŞTURULMAZ.
ADMIN_DEFAULT_EMAIL="admin@example.com"
ADMIN_DEFAULT_PASSWORD="changeme_strong_password_here"

# Virgülle ayrılmış izin verilen CORS origin listesi.
# Geliştirme: Android emülatör (10.0.2.2) ve localhost
# Production: gerçek domain adresinizi ekleyin
ALLOWED_ORIGINS="http://10.0.2.2:4000,http://localhost:4000"
